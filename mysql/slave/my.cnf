[mysqld]
# ── Replication identity ─────────────────────────────────────────────────────
server-id  = 2

# ── Relay log (receives events from master) ──────────────────────────────────
relay-log  = relay-bin

# ── Prevent accidental writes to the replica ────────────────────────────────
read_only  = 1

# ── Make replication survive restarts ────────────────────────────────────────
relay_log_recovery = 1
